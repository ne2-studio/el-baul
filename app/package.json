{
  "name": "@figma/my-make-file",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "vite build && sentry-cli sourcemaps inject --ignore 'env-config*.js' dist",
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "android:build": "vite build --mode android && cap sync android",
    "sentry:upload-sourcemaps": "sentry-cli sourcemaps upload --org pedro-pardal --project el-baul dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:image-acceptance": "playwright test --config=playwright.image-acceptance.config.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@capacitor-community/media": "^9.1.0",
    "@capacitor/android": "^8.4.2",
    "@capacitor/app": "^8.1.1",
    "@capacitor/browser": "^8.0.4",
    "@capacitor/core": "^8.4.2",
    "@capacitor/share": "^8.0.1",
    "@radix-ui/react-dropdown-menu": "2.1.6",
    "@sentry/capacitor": "^4.2.0",
    "@sentry/react": "10.60.0",
    "clsx": "2.1.1",
    "lucide-react": "0.487.0",
    "motion": "12.23.24",
    "oidc-client-ts": "^3.3.0",
    "react-oidc-context": "^3.2.0",
    "react-router-dom": "^7.12.0",
    "tailwind-merge": "3.2.0",
    "tw-animate-css": "1.3.8",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.2",
    "@playwright/test": "1.61.1",
    "@sentry/cli": "^2.58.6",
    "@storybook/addon-a11y": "^10.5.2",
    "@storybook/addon-docs": "^10.5.2",
    "@storybook/react-vite": "^10.5.2",
    "@tailwindcss/vite": "4.1.12",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "4.7.0",
    "storybook": "^10.5.2",
    "tailwindcss": "4.1.12",
    "typescript": "^5.7.2",
    "vite": "^6.4.3",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "pnpm": {
    "overrides": {
      "vite": "6.3.5"
    }
  }
}
