{
  "Auth": {
    "JwksUri": "http://localhost:5000/.well-known/jwks.json",
    "ValidIssuer": "http://localhost:5000",
    "Audience": "el-baul-app",
    "UserInfoEndpoint": "http://localhost:5000/oidc/v1/userinfo"
  },
  "AllowedHosts": "*",
  "App": {
    "PublicUrl": "http://localhost:3000"
  },
  "Api": {
    "PublicUrl": "http://localhost:5051"
  },
  "Features": {
    "MonetizationEnabled": false,
    "WelcomeEmailsEnabled": false,
    "WeeklyDigestEmailsEnabled": false,
    "ChatEnabled": true
  },
  "RateLimiter": {
    "PublicLimiter": {
      "PermitLimit": 20
    },
    "ChatLimiter": {
      "PermitLimit": 20
    }
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.AspNetCore.Hosting.Diagnostics": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Enrich": [ "FromLogContext" ],
    "Properties": {
      "Application": "ElBaul.Api.Lite"
    }
  }
}
